{
  "name": "ow-pithouse",
  "version": "0.1.0",
  "description": "Odrive Wheel Pit House — configuration tool for MKS XDrive Mini / ODESC V4.2 sim racing wheels",
  "author": "Steve",
  "license": "GPL-3.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "tsc && vite build && electron-builder --win",
    "build:mac": "tsc && vite build && electron-builder --mac",
    "build:linux": "tsc && vite build && electron-builder --linux",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "rebuild": "electron-rebuild -f -w serialport"
  },
  "dependencies": {
    "@serialport/parser-readline": "^12.0.0",
    "@tabler/icons-webfont": "^3.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/w3c-web-usb": "^1.0.14",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "jimp": "^0.22.12",
    "png-to-ico": "^2.1.0",
    "sass": "^1.77.8",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.odrive-wheel.pithouse",
    "productName": "Odrive Wheel Pit House",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "OW-Pithouse-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "OW-Pithouse-Portable-${version}.${ext}"
    }
  }
}
